# Arc testnet deployer key, 0x-prefixed (NEVER commit a real key)
PRIVATE_KEY=

# Frontend: which chain the app talks to: local | arc
# (read from the repo root by both forge scripts and Vite — see app/vite.config.ts)
VITE_CHAIN=local

# News page: GenLayer intelligent contract (news curator) on Studio testnet.
# Current live deployment of genlayer/news_curator.py (studionet resets
# occasionally — redeploy via genlayer/README.md if reads fail).
VITE_GENLAYER_NEWS_CONTRACT=0xDFEE06117b8d91b5b3e17Bfb09C6C0592ea71690
