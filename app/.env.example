# Which chain the app targets: "local" (anvil) or "arc" (Arc Testnet).
VITE_CHAIN=local

# Optional: dedicated/private Arc RPC endpoint (e.g. a keyed provider URL).
# When set, the app talks only to this endpoint at full speed — the recommended
# production setup. When unset, the app rides Arc's public gateways: Blockdaemon
# (generous limits, pruned history) first, falling back to the primary archive
# gateway (rate-limited to its ~4-call token bucket) for deep event-log history.
# See src/lib/wagmi.ts.
# VITE_ARC_RPC_URL=https://your-dedicated-arc-endpoint
# VITE_ARC_RPC_WS_URL=wss://your-dedicated-arc-endpoint

# Optional: GenLayer news contract address.
# VITE_GENLAYER_NEWS_CONTRACT=0x...
